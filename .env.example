MCP_TRANSPORT=stdio
PORT=3000
LOG_LEVEL=info

# Comma-separated list of absolute directories that tools may read from.
# Example (adjust to your environment):
# ALLOWED_DIRS=C:\Users\sunip\OneDrive\Desktop\data,C:\Temp
ALLOWED_DIRS=/absolute/path/one,/absolute/path/two

MAX_FILE_BYTES=1048576
SQLITE_MAX_ROWS=500
QUERY_TIMEOUT_MS=10000

